{
  "name": "carecom-cli",
  "version": "0.1.0",
  "description": "CLI tool for interacting with Care.com's GraphQL API",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build --compile --minify --define __APP_VERSION__='\"0.1.0\"' src/index.ts --outfile dist/carecom",
    "type-check": "bunx tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "bun-types": "^1.1.38"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
